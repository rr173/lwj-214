generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model MeetingRoom {
  id             String              @id @default(uuid())
  roomNumber     String              @unique
  name           String
  capacity       Int
  floor          Int
  isActive       Boolean             @default(true)
  splitStatus    String              @default("normal")
  parentRoomId   String?
  parentRoom     MeetingRoom?        @relation("RoomSplits", fields: [parentRoomId], references: [id])
  subRooms       MeetingRoom[]       @relation("RoomSplits")
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  facilities     RoomFacility[]
  bookings       Booking[]
  waitlists      Waitlist[]
}

model Facility {
  id         String         @id @default(uuid())
  name       String         @unique
  rooms      RoomFacility[]
}

model RoomFacility {
  roomId     String
  facilityId String
  room       MeetingRoom @relation(fields: [roomId], references: [id])
  facility   Facility    @relation(fields: [facilityId], references: [id])

  @@id([roomId, facilityId])
}

model Booking {
  id                       String    @id @default(uuid())
  bookerName               String
  roomId                   String
  roomNumber               String
  date                     String
  startTime                String
  endTime                  String
  attendeeCount            Int
  topic                    String
  isCancelled              Boolean   @default(false)
  cancelledAt              DateTime?
  cancelReason             String?
  checkInTime              DateTime?
  isReleased               Boolean   @default(false)
  releasedAt               DateTime?
  convertedFromWaitlistId  String?
  convertedFromWaitlistAt  DateTime?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  room                     MeetingRoom @relation(fields: [roomId], references: [id])
  bookingLogs              BookingLog[]
  visitors                 Visitor[]
}

model Waitlist {
  id                   String    @id @default(uuid())
  bookerName           String
  roomId               String
  roomNumber           String
  date                 String
  startTime            String
  endTime              String
  attendeeCount        Int
  requiredFacilities   String
  topic                String
  status               String    @default("pending")
  convertedAt          DateTime?
  convertedSource      String?
  convertedBookingId   String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  room                 MeetingRoom @relation(fields: [roomId], references: [id])
  logs                 BookingLog[]
}

model Visitor {
  id               String    @id @default(uuid())
  visitorName      String
  phoneLastFour    String
  visitReason      String
  hostName         String
  bookingId        String
  checkInCode      String    @unique
  status           String    @default("pending")
  checkInTime      DateTime?
  invalidatedAt    DateTime?
  invalidatedReason String?
  date             String
  startTime        String
  endTime          String
  roomNumber       String
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  booking          Booking   @relation(fields: [bookingId], references: [id])
}

model BookingLog {
  id            String    @id @default(uuid())
  date          String
  type          String
  bookingId     String?
  waitlistId    String?
  description   String
  createdAt     DateTime  @default(now())

  booking       Booking?  @relation(fields: [bookingId], references: [id])
  waitlist      Waitlist? @relation(fields: [waitlistId], references: [id])
}
