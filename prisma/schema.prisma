generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model MeetingRoom {
  id                 String              @id @default(uuid())
  roomNumber         String              @unique
  name               String
  capacity           Int
  floor              Int
  isActive           Boolean             @default(true)
  isUnderMaintenance Boolean             @default(false)
  maintenanceStartDate String?
  splitStatus        String              @default("normal")
  parentRoomId       String?
  parentRoom         MeetingRoom?        @relation("RoomSplits", fields: [parentRoomId], references: [id])
  subRooms           MeetingRoom[]       @relation("RoomSplits")
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  facilities         RoomFacility[]
  bookings           Booking[]
  waitlists          Waitlist[]
  billingRecords     BillingRecord[]
  maintenanceTickets MaintenanceTicket[]
}

model Department {
  id            String              @id @default(uuid())
  name          String              @unique
  monthlyBudget Float
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  bookings      Booking[]
  billingRecords BillingRecord[]
}

model Facility {
  id         String         @id @default(uuid())
  name       String         @unique
  rooms      RoomFacility[]
}

model RoomFacility {
  roomId     String
  facilityId String
  room       MeetingRoom @relation(fields: [roomId], references: [id])
  facility   Facility    @relation(fields: [facilityId], references: [id])

  @@id([roomId, facilityId])
}

model Booking {
  id                       String    @id @default(uuid())
  bookerName               String
  departmentId             String?
  roomId                   String
  roomNumber               String
  date                     String
  startTime                String
  endTime                  String
  attendeeCount            Int
  topic                    String
  totalCost                Float?
  refundedAmount           Float?    @default(0)
  isCancelled              Boolean   @default(false)
  cancelledAt              DateTime?
  cancelReason             String?
  checkInTime              DateTime?
  isReleased               Boolean   @default(false)
  releasedAt               DateTime?
  convertedFromWaitlistId  String?
  convertedFromWaitlistAt  DateTime?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  room                     MeetingRoom @relation(fields: [roomId], references: [id])
  department               Department? @relation(fields: [departmentId], references: [id])
  bookingLogs              BookingLog[]
  visitors                 Visitor[]
  billingRecords           BillingRecord[]
}

model BillingRecord {
  id             String    @id @default(uuid())
  departmentId   String
  bookingId      String?
  roomId         String
  roomNumber     String
  date           String
  type           String
  amount         Float
  peakHoursCost  Float     @default(0)
  offPeakHoursCost Float   @default(0)
  peakMinutes    Int       @default(0)
  offPeakMinutes Int       @default(0)
  description    String?
  createdAt      DateTime  @default(now())

  department     Department @relation(fields: [departmentId], references: [id])
  booking        Booking?   @relation(fields: [bookingId], references: [id])
  room           MeetingRoom @relation(fields: [roomId], references: [id])
}

model Waitlist {
  id                   String    @id @default(uuid())
  bookerName           String
  roomId               String
  roomNumber           String
  date                 String
  startTime            String
  endTime              String
  attendeeCount        Int
  requiredFacilities   String
  topic                String
  status               String    @default("pending")
  convertedAt          DateTime?
  convertedSource      String?
  convertedBookingId   String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  room                 MeetingRoom @relation(fields: [roomId], references: [id])
  logs                 BookingLog[]
}

model Visitor {
  id               String    @id @default(uuid())
  visitorName      String
  phoneLastFour    String
  visitReason      String
  hostName         String
  bookingId        String
  checkInCode      String    @unique
  status           String    @default("pending")
  checkInTime      DateTime?
  invalidatedAt    DateTime?
  invalidatedReason String?
  date             String
  startTime        String
  endTime          String
  roomNumber       String
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  booking          Booking   @relation(fields: [bookingId], references: [id])
}

model BookingLog {
  id            String    @id @default(uuid())
  date          String
  type          String
  bookingId     String?
  waitlistId    String?
  description   String
  createdAt     DateTime  @default(now())

  booking       Booking?  @relation(fields: [bookingId], references: [id])
  waitlist      Waitlist? @relation(fields: [waitlistId], references: [id])
}

model MaintenancePerson {
  id           String   @id @default(uuid())
  name         String
  employeeId   String   @unique
  skills       String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  schedules    MaintenanceSchedule[]
  tickets      MaintenanceTicket[]
}

model MaintenanceSchedule {
  id           String   @id @default(uuid())
  personId     String
  date         String
  startTime    String
  endTime      String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  person       MaintenancePerson @relation(fields: [personId], references: [id])

  @@unique([personId, date, startTime, endTime])
}

model MaintenanceTicket {
  id                String    @id @default(uuid())
  roomId            String
  roomNumber        String
  facilityTag       String
  description       String
  reporterName      String
  urgency           String
  status            String    @default("pending_assignment")
  assigneeId        String?
  assignee          String?
  estimatedFixDate  String?
  estimatedStartTime String?
  estimatedEndTime   String?
  actualDurationMinutes Int?
  submittedAt       DateTime  @default(now())
  assignedAt        DateTime?
  completedAt       DateTime?
  closedAt          DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  room              MeetingRoom @relation(fields: [roomId], references: [id])
  person            MaintenancePerson? @relation(fields: [assigneeId], references: [id])
}
